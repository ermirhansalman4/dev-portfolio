rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Projeleri ve blog yazılarını herkes okuyabilir.
    // Ancak sadece oluşturan kişi (authorId) silebilir ve güncelleyebilir.
    // Oluşturma işlemi (create) için giriş yapmış olmak yeterlidir.
    match /projects/{project} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    
    match /posts/{post} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    
    // Ziyaretçiler tabloya (document) sadece veri ekleyebilir (create).
    // Analytics okumaları sadece giriş yapmış üyeler (veya spesifik bir adminId) yapabilir.
    // Şimdilik sisteme üye olan herkes dashboard görebileceği için read yetkisini açalım, 
    // ama sadece dashboard'da kendi projelerini görebilecekleri için ziyaretçi verisini de herkes okuyabilir.
    match /visitors/{visitor} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
