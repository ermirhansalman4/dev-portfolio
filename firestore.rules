rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Kullanıcı Profilleri
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Projeler
    match /projects/{project} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    
    // Blog Yazıları
    match /posts/{post} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
    
    // Yorumlar
    match /comments/{comment} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.authorId);
    }
    
    // Beğeniler
    match /likes/{like} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Bildirimler (Sadece alıcı okuyabilir)
    match /notifications/{noti} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.recipientId;
    }
    
    // Bağlantılar (Takip sistemi)
    match /connections/{conn} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }
    
    // Ziyaretçi Analitiği
    match /visitors/{visitor} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
